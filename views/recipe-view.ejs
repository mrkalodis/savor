<div class="recipe-detail">
  <!-- Actions toolbar -->
  <div class="flex justify-between items-center" style="flex-wrap: wrap; gap: 1rem;">
    <div class="flex items-center gap-2">
      <a href="/recipes" class="btn btn-secondary btn-sm" style="padding: 0.5rem 1rem; font-size: 0.85rem;">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        <span>Back</span>
      </a>
      <a href="/recipes/<%= recipe.id %>/cook" class="btn btn-primary btn-sm" style="padding: 0.5rem 1rem; font-size: 0.85rem; font-weight: 700;">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span>Cook Mode</span>
      </a>
      <% if (recipe.collection_name) { %>
        <span class="tag" style="background: <%= recipe.collection_color || 'var(--primary-glow)' %>; color: #fff; border-radius: var(--radius-sm); font-size: 0.75rem; text-transform: uppercase; font-weight: 700; padding: 0.25rem 0.6rem;">
          <%= recipe.collection_name %>
        </span>
      <% } %>
    </div>
    
    <div class="flex items-center gap-2" style="flex-wrap: wrap;">
      <form action="/recipes/<%= recipe.id %>/favorite" method="POST" class="favorite-form">
        <button type="submit" class="btn btn-secondary btn-sm <%= recipe.is_favorite ? 'active' : '' %>" style="padding: 0.5rem 1rem; font-size: 0.85rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="<%= recipe.is_favorite ? 'var(--accent)' : 'none' %>" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></polygon></svg>
          <span><%= recipe.is_favorite ? 'Favorited' : 'Favorite' %></span>
        </button>
      </form>
      
      <a href="/recipes/<%= recipe.id %>/edit" class="btn btn-secondary btn-sm" style="padding: 0.5rem 1rem; font-size: 0.85rem;">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
        <span>Edit</span>
      </a>

      <!-- Share / Export Button -->
      <div style="position: relative;" class="dropdown-trigger-container">
        <button class="btn btn-secondary btn-sm" onclick="toggleShareDropdown(event)" style="padding: 0.5rem 1rem; font-size: 0.85rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          <span>Share</span>
        </button>
        <div id="share-dropdown" class="search-results-dropdown" style="right: 0; left: auto; width: 180px;">
          <a href="/recipes/<%= recipe.id %>/export/json" class="search-dropdown-item" style="font-size: 0.85rem; padding: 0.6rem 1rem;">Export as JSON</a>
          <a href="/recipes/<%= recipe.id %>/print" target="_blank" class="search-dropdown-item" style="font-size: 0.85rem; padding: 0.6rem 1rem;">Print Recipe</a>
          <a href="/recipes/<%= recipe.id %>/export/print" target="_blank" class="search-dropdown-item" style="font-size: 0.85rem; padding: 0.6rem 1rem;">Plain Print View</a>
        </div>
      </div>

      <% if (recipe.status === 'active') { %>
        <form action="/recipes/<%= recipe.id %>/archive" method="POST" style="display:inline;">
          <button type="submit" class="btn btn-secondary btn-sm" style="padding: 0.5rem 1rem; font-size: 0.85rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="21 8 21 21 3 21 3 8"/><rect x="1" y="3" width="22" height="5" rx="1"/><line x1="10" y1="12" x2="14" y2="12"/></svg>
            <span>Archive</span>
          </button>
        </form>
        <button type="button" class="btn btn-danger btn-sm" onclick="confirmDeleteRecipe(<%= recipe.id %>, 'soft')" style="padding: 0.5rem 1rem; font-size: 0.85rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
          <span>Delete</span>
        </button>
      <% } else { %>
        <form action="/recipes/<%= recipe.id %>/restore" method="POST" style="display:inline;">
          <button type="submit" class="btn btn-primary btn-sm" style="padding: 0.5rem 1rem; font-size: 0.85rem;">Restore Recipe</button>
        </form>
        <button type="button" class="btn btn-danger btn-sm" onclick="confirmDeleteRecipe(<%= recipe.id %>, 'permanent')" style="padding: 0.5rem 1rem; font-size: 0.85rem;">Permanent Delete</button>
      <% } %>
    </div>
  </div>

  <!-- Hero Header -->
  <div class="recipe-hero">
    <% if (recipe.image_path) { %>
      <img src="<%= recipe.image_path %>" alt="<%= recipe.title %>">
    <% } else { %>
      <div class="recipe-hero-placeholder" style="display: flex; align-items: center; justify-content: center; background: var(--color-bg-tertiary); height: 350px;">
        <img src="/images/placeholder.png?v=2" alt="No image" style="width: 120px; height: 120px; opacity: 0.15; object-fit: contain;">
      </div>
    <% } %>
    <div class="recipe-hero-overlay">
      <h1 style="color:#fff;"><%= recipe.title %></h1>
      <% if (recipe.description) { %>
        <p style="margin-top: 0.5rem; opacity: 0.9; max-width: 800px; font-size: 1.05rem;"><%= recipe.description %></p>
      <% } %>
    </div>
  </div>

  <!-- Metadata Cards Row -->
  <div class="recipe-meta-row">
    <% if (recipe.prep_time) { %>
      <div class="recipe-meta-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span>Prep: <strong><%= formatDuration(recipe.prep_time) %></strong></span>
      </div>
    <% } %>
    <% if (recipe.cook_time) { %>
      <div class="recipe-meta-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span>Cook: <strong><%= formatDuration(recipe.cook_time) %></strong></span>
      </div>
    <% } %>
    <% if (recipe.total_time) { %>
      <div class="recipe-meta-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span>Total: <strong><%= formatDuration(recipe.total_time) %></strong></span>
      </div>
    <% } %>
    <% if (recipe.servings) { %>
      <% let baseServingsNum = parseFloat(recipe.servings) || 4; %>
      <div class="recipe-meta-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <span>Serves: <strong><%= recipe.servings %></strong></span>
      </div>
    <% } %>
    <% if (recipe.source_url) { %>
      <div class="recipe-meta-item" style="margin-left: auto;">
        <a href="<%= recipe.source_url %>" target="_blank" class="sidebar-link" style="padding: 0.25rem 0.5rem; font-size: 0.85rem; display: flex; align-items: center; gap: 0.25rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          <span>Original Site</span>
        </a>
      </div>
    <% } %>
  </div>

  <!-- Tags Row -->
  <% if (recipe.tags && recipe.tags.length > 0) { %>
    <div class="recipe-tags">
      <% recipe.tags.forEach(tag => { %>
        <a href="/recipes?tag=<%= tag.name %>" class="tag">#<%= tag.name %></a>
      <% }) %>
    </div>
  <% } %>

  <% if (recipe.servings) { %>
  <% let baseServingsNum2 = parseFloat(recipe.servings) || 4; %>
  <!-- Serving Size Adjuster Card -->
  <div class="detail-section" style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; padding: 1.25rem 1.5rem;">
    <div style="display: flex; align-items: center; gap: 0.75rem;">
      <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--primary-glow); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </div>
      <div>
        <div style="font-weight: 700; font-size: 1rem;">Adjust Servings</div>
        <div style="font-size: 0.8rem; color: var(--text-secondary);">Ingredient amounts scale automatically</div>
      </div>
    </div>
    <div style="display: flex; align-items: center; gap: 0; background: var(--color-bg-tertiary); border: 2px solid var(--color-border); border-radius: var(--radius-md); overflow: hidden;">
      <button onclick="adjustServings(-1)" style="padding: 0.6rem 1.1rem; font-size: 1.3rem; font-weight: 700; background: transparent; border: none; color: var(--text-primary); cursor: pointer; line-height: 1; transition: background 0.15s;" onmouseover="this.style.background='var(--color-border)'" onmouseout="this.style.background='transparent'">−</button>
      <div style="padding: 0.6rem 1.25rem; font-size: 1.3rem; font-weight: 800; min-width: 3.5rem; text-align: center; border-left: 2px solid var(--color-border); border-right: 2px solid var(--color-border);">
        <strong id="servings-display" data-base-servings="<%= baseServingsNum2 %>"><%= recipe.servings %></strong>
      </div>
      <button onclick="adjustServings(1)" style="padding: 0.6rem 1.1rem; font-size: 1.3rem; font-weight: 700; background: transparent; border: none; color: var(--text-primary); cursor: pointer; line-height: 1; transition: background 0.15s;" onmouseover="this.style.background='var(--color-border)'" onmouseout="this.style.background='transparent'">+</button>
    </div>
  </div>
  <% } %>

  <!-- Two-Column Ingredients & Instructions -->
  <div class="recipe-detail-grid">
    <!-- Left Column: Ingredients -->
    <div class="detail-section" style="height: fit-content;">
      <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid var(--color-border); padding-bottom: 0.5rem; margin-bottom: 1rem;">
        <h3 style="margin: 0; border: none; padding: 0;">Ingredients</h3>
        <div style="display: flex; gap: 0.5rem;">
          <button type="button" class="btn btn-sm btn-secondary" onclick="openSubstitutes()" style="display: flex; align-items: center; gap: 0.35rem; font-size: 0.8rem; padding: 0.35rem 0.65rem;" title="View substitutions guide">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            <span>Substitutes</span>
          </button>
          <form action="/shopping-list/recipe" method="POST" style="margin: 0; display: flex;">
            <input type="hidden" name="recipe_id" value="<%= recipe.id %>">
            <button type="submit" class="btn btn-sm btn-secondary" style="display: flex; align-items: center; gap: 0.35rem; font-size: 0.8rem; padding: 0.35rem 0.65rem;" title="Add all ingredients to shopping list">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
              <span>Add to Shopping List</span>
            </button>
          </form>
        </div>
      </div>
      <ul class="ingredients-list">
        <% const ingredients = (typeof recipe.ingredients === 'string') ? JSON.parse(recipe.ingredients) : recipe.ingredients; %>
        <% if (ingredients && ingredients.length > 0) { %>
          <% ingredients.forEach((ingredient, index) => { %>
            <li>
              <input type="checkbox" id="ing-<%= index %>" class="ingredient-checkbox">
              <label for="ing-<%= index %>" class="step-text ingredient-line" data-original-text="<%= ingredient %>"><%= ingredient %></label>
            </li>
          <% }) %>
        <% } else { %>
          <li style="color: var(--text-muted);">No ingredients listed.</li>
        <% } %>
      </ul>
    </div>

    <!-- Right Column: Instructions & Notes -->
    <div>
      <div class="detail-section">
        <h3>Instructions</h3>
        <ol class="instructions-list">
          <% const instructions = (typeof recipe.instructions === 'string') ? JSON.parse(recipe.instructions) : recipe.instructions; %>
          <% if (instructions && instructions.length > 0) { %>
            <% instructions.forEach((step, index) => { %>
              <li class="instruction-step">
                <span class="step-number"><%= index + 1 %></span>
                <span class="step-text"><%= step %></span>
              </li>
            <% }) %>
          <% } else { %>
            <li style="color: var(--text-muted);">No instructions listed.</li>
          <% } %>
        </ol>
      </div>

      <% if (recipe.notes) { %>
        <div class="detail-section">
          <h3>Notes</h3>
          <p style="white-space: pre-wrap; font-size: 0.95rem; color: var(--text-secondary); line-height: 1.6;"><%= recipe.notes %></p>
        </div>
      <% } %>
    </div>
  </div>
</div>

<script>
  function toggleShareDropdown(event) {
    event.stopPropagation();
    const dropdown = document.getElementById('share-dropdown');
    dropdown.classList.toggle('open');
  }

  function confirmDeleteRecipe(id, type) {
    const modal = document.getElementById('confirm-delete-modal');
    const form = document.getElementById('confirm-delete-form');
    const methodInput = document.getElementById('confirm-delete-method');
    const message = document.getElementById('confirm-delete-message');
    
    if (type === 'soft') {
      message.innerText = 'Are you sure you want to delete this recipe? It will be moved to the trash.';
      form.action = '/recipes/' + id + '/delete';
      methodInput.value = 'POST';
    } else {
      message.innerText = 'Are you sure you want to PERMANENTLY delete this recipe? This action cannot be undone.';
      form.action = '/recipes/' + id;
      methodInput.value = 'DELETE';
    }
    
    openModal('confirm-delete-modal');
  }

  // Close share dropdown on clicking outside
  document.addEventListener('click', function(event) {
    const dropdown = document.getElementById('share-dropdown');
    if (dropdown && dropdown.classList.contains('open') && !event.target.closest('.dropdown-trigger-container')) {
      dropdown.classList.remove('open');
    }
  });
</script>
<script src="/js/serving-scaler.js"></script>

<!-- Substitutes Modal -->
<div id="substitutes-modal" class="modal-overlay">
  <div class="modal-panel" style="max-width: 500px; padding: 2rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
      <h3 style="margin: 0;">Smart Substitutions Guide</h3>
      <button class="btn-icon" onclick="closeModal('substitutes-modal')" style="font-size: 1.25rem;">&times;</button>
    </div>

    <!-- Search Input -->
    <div class="form-group" style="margin-bottom: 1.5rem;">
      <input type="text" id="sub-search-input" class="form-control" placeholder="Search ingredients (e.g. egg, cream)..." style="width: 100%;">
    </div>

    <!-- Results List -->
    <div id="substitutes-list" style="max-height: 400px; overflow-y: auto; padding-right: 0.5rem;">
      <!-- Populated dynamically by substitutes.js -->
    </div>

    <div style="display: flex; justify-content: flex-end; margin-top: 1.5rem; border-top: 1px solid var(--color-border); padding-top: 1rem;">
      <button type="button" class="btn btn-secondary" onclick="closeModal('substitutes-modal')">Close</button>
    </div>
  </div>
</div>

<script src="/js/substitutes.js"></script>

<!-- AI Companion Context -->
<script>
  const rTitle = <%- JSON.stringify(recipe.title || '') %>;
  const rDesc = <%- JSON.stringify(recipe.description || 'None') %>;
  const rIngs = <%- JSON.stringify(Array.isArray(recipe.ingredients) ? recipe.ingredients.join('\\n') : (recipe.ingredients || '')) %>;
  const rInst = <%- JSON.stringify(Array.isArray(recipe.instructions) ? recipe.instructions.join('\\n') : (recipe.instructions || '')) %>;
  
  window.currentRecipeContext = `Title: ${rTitle}\nDescription: ${rDesc}\nIngredients:\n${rIngs}\nInstructions:\n${rInst}`;
</script>
