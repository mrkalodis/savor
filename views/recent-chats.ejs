<div class="header-actions">
  <h1>Recent AI Chats</h1>
</div>

<div class="content-panel">
  <% if (!chats || chats.length === 0) { %>
    <div class="empty-state">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-muted mb-3"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
      <h3>No Recent Chats</h3>
      <p class="text-secondary">Chats are saved for 7 days. Open the AI Assistant to start a new chat!</p>
      <button class="btn btn-primary mt-3" onclick="toggleAiDrawer()">Open AI Assistant</button>
    </div>
  <% } else { %>
    <div class="recipe-grid" style="grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));">
      <% chats.forEach(chat => { %>
        <div class="recipe-card" style="padding: 1.5rem; display: flex; flex-direction: column; cursor: pointer; border-bottom-left-radius: 0; border-bottom-right-radius: 0;" onclick="loadAiChat(<%= chat.id %>)">
          <div style="flex: 1;">
            <h3 style="margin-top: 0; margin-bottom: 0.5rem; font-size: 1.1rem; color: var(--text-primary); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"><%= chat.title || 'Conversation' %></h3>
            <p style="margin: 0; font-size: 0.85rem; color: var(--text-muted);">
              Last updated: <%= chat.formattedDate %>
            </p>
          </div>
          <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
            <span class="btn btn-sm btn-outline-primary" style="padding: 0.25rem 0.5rem;">Open Chat</span>
            <form action="/api/ai/chats/<%= chat.id %>" method="POST" onsubmit="return confirm('Delete this chat history?')">
              <input type="hidden" name="_method" value="DELETE">
              <button type="submit" class="btn btn-sm" style="background: none; border: none; color: var(--danger); padding: 0;">Delete</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
