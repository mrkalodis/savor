<div style="display: flex; flex-direction: column; gap: 2rem; max-width: 800px; margin: 0 auto;">
  <% if (typeof flashError !== 'undefined' && flashError) { %>
    <div style="padding: 1rem 1.25rem; background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.3); border-radius: var(--radius-lg); color: var(--danger); display: flex; align-items: center; gap: 0.75rem;">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <span><strong>Error:</strong> <%= flashError %></span>
    </div>
  <% } %>
  <% if (typeof flashSuccess !== 'undefined' && flashSuccess) { %>
    <div style="padding: 1rem 1.25rem; background: rgba(34,197,94,0.12); border: 1px solid rgba(34,197,94,0.3); border-radius: var(--radius-lg); color: var(--success); display: flex; align-items: center; gap: 0.75rem;">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      <span><strong>Success:</strong> <%= flashSuccess %></span>
    </div>
  <% } %>

  <h2>Pantry Staples</h2>
  <p style="color: var(--text-secondary); margin-top: -1.5rem; font-size: 0.95rem;">Configure basics (e.g. salt, water, sugar, oils) that Savor should pre-check automatically on your shopping list when importing recipes.</p>

  <!-- Staples configuration section -->
  <div class="settings-section">
    <h3>Manage Exclusions List</h3>
    <p style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 1.5rem;">Savor checks incoming recipe lines against this list of keywords (case-insensitive). If a match is found, the ingredient is automatically marked as checked off.</p>
    
    <!-- Add new staple form -->
    <form action="/settings/pantry" method="POST" style="margin-bottom: 2rem; display: flex; gap: 0.5rem; max-width: 400px;">
      <input type="text" name="name" placeholder="e.g. baking powder" required class="form-control" style="font-size: 0.9rem; padding: 0.55rem 0.85rem;">
      <button type="submit" class="btn btn-primary" style="flex-shrink: 0; padding: 0.55rem 1.25rem;">Add Keyword</button>
    </form>

    <!-- Staples listing tags -->
    <div style="display: flex; flex-wrap: wrap; gap: 0.6rem; padding: 1rem; background: var(--bg-tertiary); border-radius: var(--radius-lg); border: 1px solid var(--border); min-height: 100px;">
      <% if (typeof staples !== 'undefined' && staples.length > 0) { %>
        <% staples.forEach(s => { %>
          <div style="display: inline-flex; align-items: center; gap: 0.5rem; background: var(--bg-surface); padding: 0.35rem 0.85rem; border-radius: var(--radius-full); border: 1px solid var(--border); font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">
            <span><%= s.name %></span>
            <form action="/settings/pantry/<%= s.id %>/delete" method="POST" style="display: inline; margin: 0; padding: 0;">
              <button type="submit" style="background: none; border: none; padding: 0; color: var(--text-muted); cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; line-height: 1;" title="Remove <%= s.name %>">&times;</button>
            </form>
          </div>
        <% }) %>
      <% } else { %>
        <div style="width: 100%; text-align: center; color: var(--text-muted); font-size: 0.9rem; padding: 1.5rem 0;">
          No staples configured. Add some keywords above.
        </div>
      <% } %>
    </div>
  </div>
</div>
