<div style="display: flex; flex-direction: column; gap: 1.5rem; max-width: 750px; margin: 0 auto;">
  <!-- Header row -->
  <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
    <div>
      <h2>Shopping List</h2>
      <p style="color: var(--color-text-secondary); font-size: 0.95rem; margin-top: 0.25rem;">
        Manage your grocery checklist and import recipe ingredients.
      </p>
    </div>
    
    <div style="display: flex; gap: 0.5rem;">
      <button class="btn btn-sm btn-secondary" onclick="openModal('import-recipe-modal')">Add from Recipe</button>
      <form action="/shopping-list/clear-checked" method="POST" style="margin: 0;">
        <button type="submit" class="btn btn-sm btn-secondary">Clear Completed</button>
      </form>
      <form action="/shopping-list/clear-all" method="POST" onsubmit="return confirm('Clear the entire shopping list?');" style="margin: 0;">
        <button type="submit" class="btn btn-sm btn-danger">Clear All</button>
      </form>
    </div>
  </div>

  <div class="detail-section" style="padding: 1.5rem; display: flex; flex-direction: column; gap: 1.5rem;">
    <!-- Quick add form -->
    <form action="/shopping-list" method="POST" style="margin: 0; display: flex; gap: 0.75rem; flex-wrap: wrap;">
      <div style="flex-grow: 2; min-width: 200px;">
        <input type="text" name="name" class="form-control" placeholder="Add item (e.g. Milk, Eggs, Garlic)..." required style="width: 100%;">
      </div>
      <div style="flex-grow: 1; max-width: 150px; min-width: 90px;">
        <input type="text" name="quantity" class="form-control" placeholder="Qty (e.g. 1 gal, 2)" style="width: 100%;">
      </div>
      <button type="submit" class="btn btn-primary">Add Item</button>
    </form>

    <!-- Grocery list -->
    <% if (items.length === 0) { %>
      <div style="text-align: center; padding: 3rem 1.5rem; color: var(--color-text-tertiary);">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 1rem; opacity: 0.6;"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        <h4 style="margin: 0 0 0.25rem 0; color: var(--color-text-secondary);">Your shopping list is empty</h4>
        <p style="font-size: 0.85rem; margin: 0;">Add items manually above, or import them directly from a recipe.</p>
      </div>
    <% } else { %>
      <div style="display: flex; flex-direction: column; gap: 0.25rem;">
        <% items.forEach(item => { %>
          <div class="shopping-item-row" style="display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); background: var(--color-bg-secondary); transition: all var(--transition); gap: 1rem; <%= item.checked ? 'opacity: 0.55; background: var(--color-bg-tertiary);' : '' %>">
            <div style="display: flex; align-items: center; gap: 0.75rem; flex-grow: 1; overflow: hidden;">
              <input type="checkbox" class="shopping-item-checkbox" data-id="<%= item.id %>" <%= item.checked ? 'checked' : '' %> style="width: 18px; height: 18px; cursor: pointer; flex-shrink: 0;">
              
              <div style="overflow: hidden; flex-grow: 1;">
                <span class="shopping-item-name" style="font-weight: 550; font-size: 0.95rem; <%= item.checked ? 'text-decoration: line-through; color: var(--color-text-tertiary);' : 'color: var(--color-text);' %>">
                  <% if (item.quantity) { %>
                    <strong style="color: var(--color-primary); font-weight: 600; margin-right: 0.25rem;"><%= item.quantity %></strong>
                  <% } %>
                  <%= item.name %>
                </span>
                
                <% if (item.recipe_title) { %>
                  <div style="font-size: 0.75rem; color: var(--color-text-tertiary); margin-top: 0.1rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                    Added from: <a href="/recipes/<%= item.recipe_id %>" style="color: inherit; text-decoration: none; border-bottom: 1px dashed var(--color-border);"><%= item.recipe_title %></a>
                  </div>
                <% } %>
              </div>
            </div>

            <form action="/shopping-list/<%= item.id %>/delete" method="POST" style="margin: 0; flex-shrink: 0;">
              <button type="submit" class="btn-icon" style="color: var(--color-danger); width: 28px; height: 28px;" title="Delete">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
              </button>
            </form>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<!-- Modal Dialog -->
<div id="import-recipe-modal" class="modal-overlay">
  <div class="modal-panel" style="max-width: 450px; padding: 2rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
      <h3 style="margin: 0;">Import Recipe Ingredients</h3>
      <button class="btn-icon" onclick="closeModal('import-recipe-modal')" style="font-size: 1.25rem;">&times;</button>
    </div>

    <p style="font-size: 0.85rem; color: var(--color-text-secondary); margin-bottom: 1.5rem;">
      Choose a recipe to automatically parse and load all of its ingredients directly into your shopping checklist.
    </p>

    <form action="/shopping-list/recipe" method="POST">
      <div class="form-group" style="margin-bottom: 1.5rem;">
        <label for="import-recipe-select" class="form-label">Recipe</label>
        <select id="import-recipe-select" name="recipe_id" class="form-control" required>
          <option value="">-- Select a Recipe --</option>
          <% recipes.forEach(r => { %>
            <option value="<%= r.id %>"><%= r.title %></option>
          <% }) %>
        </select>
      </div>

      <div style="display: flex; justify-content: flex-end; gap: 0.75rem;">
        <button type="button" class="btn btn-secondary" onclick="closeModal('import-recipe-modal')">Cancel</button>
        <button type="submit" class="btn btn-primary">Import Ingredients</button>
      </div>
    </form>
  </div>
</div>

<script>
  // Setup checkbox toggle AJAX handlers
  document.querySelectorAll('.shopping-item-checkbox').forEach(box => {
    box.addEventListener('change', function() {
      const id = this.dataset.id;
      const checked = this.checked;
      const row = this.closest('.shopping-item-row');
      const textSpan = row.querySelector('.shopping-item-name');
      
      // Update local styles immediately for snappy feel
      if (checked) {
        row.style.opacity = '0.55';
        row.style.background = 'var(--color-bg-tertiary)';
        if (textSpan) {
          textSpan.style.textDecoration = 'line-through';
          textSpan.style.color = 'var(--color-text-tertiary)';
        }
      } else {
        row.style.opacity = '1';
        row.style.background = 'var(--color-bg-secondary)';
        if (textSpan) {
          textSpan.style.textDecoration = 'none';
          textSpan.style.color = 'var(--color-text)';
        }
      }
      
      // Send toggle status back to server in background
      fetch('/shopping-list/check', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({ id, checked })
      })
      .then(res => res.json())
      .then(data => {
        if (!data.success) {
          // Revert style on error
          window.location.reload();
        }
      })
      .catch(err => {
        console.error('Failed to toggle shopping item status:', err);
        window.location.reload();
      });
    });
  });
</script>
