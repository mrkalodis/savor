<!DOCTYPE html>
<html lang="en" data-theme="<%= typeof theme !== 'undefined' ? (theme === 'system' ? '' : theme) : '' %>" style="--primary: <%= typeof accentColors !== 'undefined' ? accentColors.primary : '#6366f1' %>; --primary-hover: <%= typeof accentColors !== 'undefined' ? accentColors.hover : '#4f46e5' %>; --primary-glow: <%= typeof accentColors !== 'undefined' ? accentColors.glow : 'rgba(99, 102, 241, 0.12)' %>;">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  
  <!-- PWA Meta Tags -->
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#111827">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Savor">
  <link rel="apple-touch-icon" href="/icons/icon-192x192.png">

  <title><%= typeof title !== 'undefined' ? title + ' — Savor' : 'Savor' %></title>
  
  <link rel="icon" href="/favicon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">

  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js').catch(err => {
          console.error('ServiceWorker registration failed: ', err);
        });
      });
    }
  </script>
</head>
<body>
  <% if (typeof view !== 'undefined' && (view === 'login' || view === 'print' || view === 'cook')) { %>
    <%- include('../' + view, locals) %>
  <% } else { %>
    <%- include('../partials/header', locals) %>

    <!-- Mobile sidebar overlay backdrop -->
    <div class="sidebar-overlay" id="sidebar-overlay" onclick="closeSidebar()"></div>

    <div class="app-layout" id="app-layout">
    <script>
      if (localStorage.getItem('sidebarPinned') === 'true') {
        document.getElementById('app-layout').classList.add('sidebar-pinned');
      }
    </script>
      <aside class="sidebar" id="sidebar">
        <nav class="sidebar-nav">

          <!-- Core navigation -->
          <a href="/" class="sidebar-link <%= currentPath === '/' ? 'active' : '' %>" title="Dashboard">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span>Dashboard</span>
          </a>

          <a href="/recipes" class="sidebar-link <%= currentPath === '/recipes' && !locals.isFavorites ? 'active' : '' %>" title="All Recipes">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"/><path d="M6 6h10M6 10h10"/></svg>
            <span>All Recipes</span>
          </a>

          <a href="/recipes?favorites=1" class="sidebar-link <%= currentPath === '/recipes' && locals.isFavorites ? 'active' : '' %>" title="Favorites">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <span>Favorites</span>
          </a>

          <a href="/meal-planner" class="sidebar-link <%= currentPath === '/meal-planner' ? 'active' : '' %>" title="Meal Planner">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <span>Meal Planner</span>
          </a>

          <a href="/shopping-list" class="sidebar-link <%= currentPath === '/shopping-list' ? 'active' : '' %>" title="Shopping List">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            <span>Shopping List</span>
          </a>

          <a href="/pantry-staples" class="sidebar-link <%= currentPath === '/pantry-staples' ? 'active' : '' %>" title="Pantry Staples">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            <span>Pantry Staples</span>
          </a>

          <!-- Collections section -->
          <div class="sidebar-section">
            <div class="sidebar-section-header">
              <span>Collections</span>
              <button class="btn-icon" onclick="openModal('create-collection-modal')" title="New Collection" style="width: 22px; height: 22px; padding: 0;">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </button>
            </div>
            <div id="collections-list-container" data-sortable="collection">
              <% if (typeof sidebarCollections !== 'undefined' && sidebarCollections.length > 0) { %>
                <% sidebarCollections.forEach(function(c) { %>
                  <div class="sidebar-link collection-link <%= currentPath === '/collections/' + c.id ? 'active' : '' %>" data-sortable-id="<%= c.id %>" data-sortable-type="collection" title="<%= c.name %>">
                    <div class="collection-info">
                      <span class="drag-handle" style="display:none;">::</span>
                      <span class="collection-dot" style="background: <%= c.color %>"></span>
                      <a href="/collections/<%= c.id %>" class="collection-name" style="flex-grow:1; color: inherit;"><%= c.name %></a>
                    </div>
                    <span class="badge"><%= c.recipe_count || 0 %></span>
                  </div>
                <% }) %>
              <% } %>
            </div>
          </div>

          <!-- Utility links (archive/trash) -->
          <% if (typeof archivedCount !== 'undefined' && archivedCount > 0) { %>
            <a href="/archive" class="sidebar-link <%= currentPath === '/archive' ? 'active' : '' %>" title="Archive">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="21 8 21 21 3 21 3 8"/><rect x="1" y="3" width="22" height="5" rx="1"/><line x1="10" y1="12" x2="14" y2="12"/></svg>
              <span>Archive</span>
            </a>
          <% } %>
          <% if (typeof deletedCount !== 'undefined' && deletedCount > 0) { %>
            <a href="/trash" class="sidebar-link <%= currentPath === '/trash' ? 'active' : '' %>" title="Trash">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
              <span>Trash</span>
            </a>
          <% } %>

          <!-- Settings & Pin pinned at bottom -->
          <div style="margin-top: auto; padding-top: 1rem; border-top: 1px solid var(--border); display: flex; flex-direction: column; gap: 0.25rem;">
            <button class="sidebar-link" id="sidebar-pin-btn" onclick="toggleSidebarPin()" title="Pin Sidebar" style="background: none; border: none; width: 100%; cursor: pointer; text-align: left; padding: 0.75rem 1.1rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="17" x2="12" y2="22"/><path d="M5 17h14v-1.76a2 2 0 0 0-.44-1.24l-2.78-3.55A2 2 0 0 1 15 9.24V5a3 3 0 0 0-6 0v4.24a2 2 0 0 1-.78 1.57l-2.78 3.55A2 2 0 0 0 5 15.24V17z"/></svg>
              <span>Pin Sidebar</span>
            </button>

            <a href="/recent-chats" class="sidebar-link <%= typeof currentPath !== 'undefined' && currentPath === '/recent-chats' ? 'active' : '' %>" title="Recent Chats">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
              <span>Recent Chats</span>
            </a>

            <a href="/settings" class="sidebar-link <%= typeof currentPath !== 'undefined' && currentPath === '/settings' ? 'active' : '' %>" title="Settings">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
              <span>Settings</span>
            </a>
          </div>

        </nav>
      </aside>

      <main class="main-content">
        <%- include('../' + view, locals) %>
      </main>
    </div>

    <div class="toast-container" id="toast-container"></div>
    <%- include('../partials/modal', locals) %>
  <% } %>
  <script src="/js/app.js"></script>
  <script src="/js/drag-drop.js"></script>

  <script>
    // Pin / Unpin Sidebar handler
    function toggleSidebarPin() {
      const layout = document.getElementById('app-layout');
      const isPinned = layout.classList.toggle('sidebar-pinned');
      localStorage.setItem('sidebarPinned', isPinned ? 'true' : 'false');
      updatePinButtonUI(isPinned);
    }

    function updatePinButtonUI(isPinned) {
      const pinBtn = document.getElementById('sidebar-pin-btn');
      if (pinBtn) {
        const text = pinBtn.querySelector('span');
        const icon = pinBtn.querySelector('svg');
        if (isPinned) {
          text.textContent = 'Unpin Sidebar';
          pinBtn.title = 'Unpin Sidebar';
          icon.style.color = 'var(--primary)';
        } else {
          text.textContent = 'Pin Sidebar';
          pinBtn.title = 'Pin Sidebar';
          icon.style.color = '';
        }
      }
    }

    // Mobile sidebar helpers
    function closeSidebar() {
      document.getElementById('sidebar').classList.remove('open');
      document.getElementById('sidebar-overlay').classList.remove('open');
    }
    // Patch the existing mobile-menu-toggle to also show the overlay
    document.addEventListener('DOMContentLoaded', function() {
      const toggle = document.getElementById('mobile-menu-toggle');
      if (toggle) {
        toggle.addEventListener('click', function() {
          const sidebar = document.getElementById('sidebar');
          const overlay = document.getElementById('sidebar-overlay');
          const isOpen = sidebar.classList.toggle('open');
          overlay.classList.toggle('open', isOpen);
        });
      }

      // Initialize Pin Button UI state on load
      const isPinned = localStorage.getItem('sidebarPinned') === 'true';
      updatePinButtonUI(isPinned);
    });
  </script>

  <% if (locals.aiEnabled) { %>
    <%- include('../partials/ai-chat', locals) %>
  <% } %>
</body>
</html>
