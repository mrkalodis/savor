<!-- Floating AI Button -->
<button id="ai-chat-toggle" class="ai-chat-toggle" onclick="toggleAiDrawer()" aria-label="Open AI Assistant">
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 2a10 10 0 0 1 10 10c0 5.523-4.477 10-10 10-2.3 0-4.43-.78-6.1-2.1L2 22l2.1-3.9C2.78 16.43 2 14.3 2 12 2 6.477 6.477 2 12 2z" />
    <path d="M8 12h.01" />
    <path d="M12 12h.01" />
    <path d="M16 12h.01" />
  </svg>
</button>

<!-- AI Assistant Drawer -->
<div id="ai-chat-drawer" class="ai-chat-drawer">
  <div class="ai-drawer-header">
    <div class="ai-drawer-title">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 0 1 10 10c0 5.523-4.477 10-10 10-2.3 0-4.43-.78-6.1-2.1L2 22l2.1-3.9C2.78 16.43 2 14.3 2 12 2 6.477 6.477 2 12 2z"/></svg>
      <strong>Savor AI</strong>
    </div>
    <div style="display:flex; gap: 0.5rem">
      <button class="ai-drawer-close" onclick="clearAiChat()" title="Clear Chat">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
      </button>
      <button class="ai-drawer-close" onclick="toggleAiDrawer()" title="Close">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>
  </div>

  <div class="ai-drawer-body" id="ai-chat-history">
    <div class="ai-message ai-message-assistant" id="ai-welcome-msg">
      <div class="ai-message-bubble">
        Hello! I'm your local Savor kitchen assistant. I run entirely on your machine. Need a substitution or recipe idea?
      </div>
    </div>
  </div>

  <!-- Loading Indicator -->
  <div class="ai-drawer-loading" id="ai-loading" style="display: none;">
    <div class="typing-indicator">
      <span></span><span></span><span></span>
    </div>
  </div>

  <div class="ai-drawer-footer">
    <div class="ai-quick-actions" id="ai-quick-actions">
      <button onclick="sendAiMessage('Can you suggest a quick dinner recipe?')">Suggest a meal</button>
      <button onclick="sendAiMessage('I need help substituting an ingredient I don\'t have.')">Substitute help</button>
      <button onclick="sendAiMessage('How do I store fresh herbs so they last longer?')">Storage tips</button>
      <button onclick="sendAiMessage('What can I cook with chicken, rice, and broccoli?')">Pantry ideas</button>
    </div>
    <form id="ai-chat-form" onsubmit="handleAiSubmit(event)">
      <input type="text" id="ai-chat-input" placeholder="Ask me anything..." required autocomplete="off" />
      <button type="submit" id="ai-send-btn" aria-label="Send">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
      </button>
      <button type="button" id="ai-stop-btn" onclick="abortAiGeneration()" aria-label="Stop Generating" style="display: none; background: var(--danger) !important; color: white;">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect></svg>
      </button>
    </form>
  </div>
</div>

<script>
  let aiHistory = [];
  let currentChatId = null;
  let activeAbortController = null;

  function abortAiGeneration() {
    if (activeAbortController) {
      activeAbortController.abort();
      activeAbortController = null;
    }
  }

  async function toggleAiDrawer() {
    const drawer = document.getElementById('ai-chat-drawer');
    drawer.classList.toggle('open');
    if (drawer.classList.contains('open')) {
      document.getElementById('ai-chat-input').focus();
    } else {
      await saveCurrentChat();
    }
  }

  async function clearAiChat() {
    await saveCurrentChat();
    aiHistory = [];
    currentChatId = null;
    const historyDiv = document.getElementById('ai-chat-history');
    historyDiv.innerHTML = `
      <div class="ai-message ai-message-assistant" id="ai-welcome-msg">
        <div class="ai-message-bubble">
          Chat cleared. How can I help you?
        </div>
      </div>
    `;
    document.getElementById('ai-quick-actions').style.display = 'flex';
  }

  async function saveCurrentChat() {
    if (aiHistory.length === 0) return;
    try {
      const res = await fetch('/api/ai/chats', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: currentChatId, history: aiHistory, title: aiHistory[0].content })
      });
      const data = await res.json();
      if (data.success && data.id) {
        currentChatId = data.id;
      }
    } catch (e) {
      console.error('Failed to save chat', e);
    }
  }

  function importRecipe(text) {
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = '/recipes/new/ai';
    
    const input = document.createElement('input');
    input.type = 'hidden';
    input.name = 'text';
    input.value = text;
    
    form.appendChild(input);
    document.body.appendChild(form);
    form.submit();
  }

  function appendAiMessage(role, content) {
    const historyDiv = document.getElementById('ai-chat-history');
    const msgDiv = document.createElement('div');
    msgDiv.className = 'ai-message ai-message-' + role;
    
    const bubbleDiv = document.createElement('div');
    bubbleDiv.className = 'ai-message-bubble';
    
    let htmlContent = content.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
    htmlContent = htmlContent.replace(/\n/g, '<br/>');
    bubbleDiv.innerHTML = htmlContent;
    
    if (role === 'assistant' && (content.toLowerCase().includes('ingredient') || content.toLowerCase().includes('instruction'))) {
      const importBtn = document.createElement('button');
      importBtn.className = 'btn btn-outline-primary mt-3';
      importBtn.style.padding = '4px 8px';
      importBtn.style.fontSize = '0.8rem';
      importBtn.innerText = 'Import to Savor';
      importBtn.onclick = () => importRecipe(content);
      bubbleDiv.appendChild(document.createElement('br'));
      bubbleDiv.appendChild(importBtn);
    }
    
    msgDiv.appendChild(bubbleDiv);
    historyDiv.appendChild(msgDiv);
    historyDiv.scrollTop = historyDiv.scrollHeight;
  }

  async function sendAiMessage(messageText) {
    if (!messageText.trim()) return;
    
    document.getElementById('ai-quick-actions').style.display = 'none';
    
    appendAiMessage('user', messageText);
    document.getElementById('ai-chat-input').value = '';
    document.getElementById('ai-loading').style.display = 'block';
    
    // Toggle stop/send buttons
    document.getElementById('ai-send-btn').style.display = 'none';
    document.getElementById('ai-stop-btn').style.display = 'flex';

    const historyForApi = [...aiHistory];
    aiHistory.push({ role: 'user', content: messageText });

    activeAbortController = new AbortController();

    try {
      const response = await fetch('/api/ai/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        signal: activeAbortController.signal,
        body: JSON.stringify({
          message: messageText,
          history: historyForApi,
          context: typeof window.currentRecipeContext !== 'undefined' ? window.currentRecipeContext : null
        })
      });

      document.getElementById('ai-loading').style.display = 'none';

      if (!response.ok) {
        throw new Error('Failed to connect to AI');
      }

      // Create streaming bubble
      const historyDiv = document.getElementById('ai-chat-history');
      const msgDiv = document.createElement('div');
      msgDiv.className = 'ai-message ai-message-assistant';
      const bubbleDiv = document.createElement('div');
      bubbleDiv.className = 'ai-message-bubble';
      msgDiv.appendChild(bubbleDiv);
      historyDiv.appendChild(msgDiv);

      const reader = response.body.getReader();
      const decoder = new TextDecoder("utf-8");
      let fullResponse = '';

      try {
        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          const chunk = decoder.decode(value, { stream: true });
          fullResponse += chunk;
          
          let htmlContent = fullResponse.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
          htmlContent = htmlContent.replace(/\n/g, '<br/>');
          bubbleDiv.innerHTML = htmlContent;
          historyDiv.scrollTop = historyDiv.scrollHeight;
        }
      } catch (streamErr) {
        if (streamErr.name === 'AbortError') {
          console.log('Streaming generation aborted by user.');
        } else {
          throw streamErr;
        }
      }
      
      aiHistory.push({ role: 'assistant', content: fullResponse });
      
      if (fullResponse.toLowerCase().includes('ingredient') || fullResponse.toLowerCase().includes('instruction')) {
        const importBtn = document.createElement('button');
        importBtn.className = 'btn btn-outline-primary mt-3';
        importBtn.style.padding = '4px 8px';
        importBtn.style.fontSize = '0.8rem';
        importBtn.innerText = 'Import to Savor';
        importBtn.onclick = () => importRecipe(fullResponse);
        bubbleDiv.appendChild(document.createElement('br'));
        bubbleDiv.appendChild(importBtn);
      }
      
      await saveCurrentChat();
      
    } catch (err) {
      document.getElementById('ai-loading').style.display = 'none';
      if (err.name === 'AbortError') {
        console.log('Generation aborted by user.');
      } else {
        appendAiMessage('assistant', `**Error:** ${err.message}. Make sure Ollama is running.`);
      }
    } finally {
      activeAbortController = null;
      document.getElementById('ai-stop-btn').style.display = 'none';
      document.getElementById('ai-send-btn').style.display = 'flex';
      document.getElementById('ai-loading').style.display = 'none';
    }
  }

  function handleAiSubmit(e) {
    e.preventDefault();
    const input = document.getElementById('ai-chat-input');
    sendAiMessage(input.value);
  }

  // Load chat logic for external clicks
  window.loadAiChat = async function(id) {
    try {
      const res = await fetch('/api/ai/chats/' + id);
      const chat = await res.json();
      if (!chat.messages) return;
      
      aiHistory = chat.messages;
      currentChatId = chat.id;
      
      const historyDiv = document.getElementById('ai-chat-history');
      historyDiv.innerHTML = '';
      document.getElementById('ai-quick-actions').style.display = 'none';
      
      aiHistory.forEach(msg => {
        appendAiMessage(msg.role, msg.content);
      });
      
      const drawer = document.getElementById('ai-chat-drawer');
      if (!drawer.classList.contains('open')) {
        drawer.classList.add('open');
      }
    } catch (e) {
      console.error('Failed to load chat', e);
    }
  };
</script>
