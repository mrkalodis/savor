<div style="display: flex; flex-direction: column; gap: 2rem;">
  <% if (typeof showOnboarding !== 'undefined' && showOnboarding) { %>
    <!-- First Run Onboarding Welcome Wizard -->
    <div class="detail-section" style="max-width: 650px; margin: 2rem auto; padding: 3rem 2.5rem; text-align: center; box-shadow: var(--shadow-lg); border-radius: var(--radius-xl); border-top: 6px solid var(--primary);">
      <!-- Stylized logo icon -->
      <div style="background-color: var(--primary-glow); color: var(--primary); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem auto;">
        <img src="/images/logo.png?v=2" alt="Savor Logo" style="width: 50px; height: 50px; opacity: 0.85; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.15)); object-fit: contain; border-radius: var(--radius-sm);">
      </div>

      <h2 style="margin-bottom: 0.75rem; font-size: 2rem; font-weight: 800;">Welcome to Savor</h2>
      <p style="color: var(--text-secondary); margin-bottom: 2.5rem; font-size: 1.05rem; line-height: 1.6;">Let's get your personal recipe container set up. Choose one of the options below to get started:</p>
      
      <div style="display: flex; flex-direction: column; gap: 1rem; text-align: left; max-width: 480px; margin: 0 auto 2.5rem auto;">
        <div style="display: flex; align-items: center; gap: 1rem; padding: 1rem; border: 1px solid var(--border); border-radius: var(--radius-lg); background-color: var(--bg-surface); cursor: pointer; transition: transform var(--transition-fast);" onclick="openModal('create-collection-modal')">
          <div style="background-color: var(--primary-glow); color: var(--primary); padding: 0.5rem; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </div>
          <div>
            <strong style="font-size: 0.95rem; color: var(--text-primary);">Create your first collection</strong>
            <p style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.15rem;">Group your recipes by tags like Dinner, Breakfast, Desserts</p>
          </div>
        </div>

        <a href="/recipes/new?import=1" style="display: flex; align-items: center; gap: 1rem; padding: 1rem; border: 1px solid var(--border); border-radius: var(--radius-lg); background-color: var(--bg-surface); cursor: pointer; transition: transform var(--transition-fast);">
          <div style="background-color: rgba(59, 130, 246, 0.15); color: #3b82f6; padding: 0.5rem; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          </div>
          <div>
            <strong style="font-size: 0.95rem; color: var(--text-primary);">Import a recipe from a website</strong>
            <p style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.15rem;">Automatically fetch ingredients and steps from any recipe link</p>
          </div>
        </a>

        <a href="/recipes/new" style="display: flex; align-items: center; gap: 1rem; padding: 1rem; border: 1px solid var(--border); border-radius: var(--radius-lg); background-color: var(--bg-surface); cursor: pointer; transition: transform var(--transition-fast);">
          <div style="background-color: rgba(16, 185, 129, 0.15); color: #10b981; padding: 0.5rem; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
          </div>
          <div>
            <strong style="font-size: 0.95rem; color: var(--text-primary);">Create a recipe manually</strong>
            <p style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.15rem;">Type or paste in your favorite family recipe cards</p>
          </div>
        </a>
      </div>

      <form action="/onboarding/complete" method="POST">
        <button type="submit" class="btn btn-secondary btn-sm" style="color: var(--text-secondary); border: none; background: none; font-size: 0.85rem; text-decoration: underline;">Skip and start with an empty library</button>
      </form>
    </div>
  <% } else { %>
    <!-- Welcome banner -->
    <div style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-hover) 100%); color: #fff; padding: 2.5rem; border-radius: var(--radius-xl); box-shadow: var(--shadow-md); position: relative; overflow: hidden;">
      <div style="position: relative; z-index: 10; max-width: 600px;">
        <h2 style="margin-bottom: 0.5rem; color:#fff;">Welcome to Savor</h2>
        <p style="font-size: 1.05rem; opacity: 0.9;">Your personal recipe container. Organize, discover, and import your favorite dishes, self-hosted on your home server.</p>
        <div style="display: flex; gap: 1rem; margin-top: 1.5rem; flex-wrap: wrap;">
          <a href="/recipes/new" class="btn btn-secondary" style="background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.3); color: #fff; backdrop-filter: blur(10px);">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            <span>Create Manually</span>
          </a>
          <a href="/recipes/new?import=1" class="btn btn-secondary" style="background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.3); color: #fff; backdrop-filter: blur(10px);">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            <span>Import from Web</span>
          </a>
        </div>
      </div>
      <!-- Abstract decorative background shape -->
      <div style="position: absolute; right: -50px; bottom: -50px; width: 300px; height: 300px; border-radius: 50%; background: rgba(255, 255, 255, 0.08); pointer-events: none;"></div>
    </div>

    <!-- Stats row -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem;">
      <div class="detail-section" style="padding: 1.25rem 1.5rem; margin-bottom: 0; display: flex; align-items: center; gap: 1rem;">
        <div style="background-color: var(--primary-glow); color: var(--primary); padding: 0.75rem; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center;">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"/><path d="M6 6h10M6 10h10"/></svg>
        </div>
        <div>
          <h4 style="font-size: 1.5rem; font-weight: 800;"><%= stats.totalRecipes || 0 %></h4>
          <span style="font-size: 0.85rem; color: var(--text-secondary);">Total Recipes</span>
        </div>
      </div>
      <div class="detail-section" style="padding: 1.25rem 1.5rem; margin-bottom: 0; display: flex; align-items: center; gap: 1rem;">
        <div style="background-color: rgba(59, 130, 246, 0.15); color: #3b82f6; padding: 0.75rem; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center;">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
        </div>
        <div>
          <h4 style="font-size: 1.5rem; font-weight: 800;"><%= stats.totalCollections || 0 %></h4>
          <span style="font-size: 0.85rem; color: var(--text-secondary);">Collections</span>
        </div>
      </div>
      <div class="detail-section" style="padding: 1.25rem 1.5rem; margin-bottom: 0; display: flex; align-items: center; gap: 1rem;">
        <div style="background-color: rgba(245, 158, 11, 0.15); color: var(--accent); padding: 0.75rem; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center;">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <div>
          <h4 style="font-size: 1.5rem; font-weight: 800;"><%= stats.totalFavorites || 0 %></h4>
          <span style="font-size: 0.85rem; color: var(--text-secondary);">Favorites</span>
        </div>
      </div>
    </div>

    <% if (recentRecipes.length === 0) { %>
      <!-- Empty state -->
      <div class="empty-state detail-section">
        <img src="/images/placeholder.png?v=2" alt="No recipes" style="width: 100px; height: 100px; opacity: 0.15; margin: 0 auto 1.5rem auto; display: block; object-fit: contain; border-radius: var(--radius-md);">
        <h3>Start your cooking library</h3>
        <p>Create recipes manually, upload photos, or import them directly from popular websites with a single click.</p>
        <a href="/recipes/new" class="btn btn-primary">Add a Recipe</a>
      </div>
    <% } else { %>
    <!-- Dashboard lists -->
    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem;">
      <!-- Recent Recipes -->
      <div>
        <div class="flex justify-between items-center mb-4">
          <h3>Recent Recipes</h3>
          <a href="/recipes" class="sidebar-link" style="padding: 0.25rem 0.5rem; font-size: 0.85rem; display: flex; align-items: center; gap: 0.25rem;">
            <span>View All</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        </div>
        <div class="recipe-grid" style="grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1.5rem; margin-top: 0;">
          <% recentRecipes.forEach(recipe => { %>
            <%- include('partials/recipe-card', { recipe: recipe, formatDuration: formatDuration }) %>
          <% }) %>
        </div>
      </div>

      <!-- Sidebar widgets: Favorite Recipes & Quick Stats -->
      <div style="display: flex; flex-direction: column; gap: 2rem;">
        <div>
          <h3 class="mb-4">Favorites</h3>
          <div style="display: flex; flex-direction: column; gap: 1rem;">
            <% if (favoriteRecipes.length === 0) { %>
              <div style="padding: 2rem; text-align: center; border: 1px dashed var(--border); border-radius: var(--radius-lg); color: var(--text-muted);">
                <p style="font-size: 0.85rem;">No favorite recipes yet. Click the star icon on any recipe to add it here.</p>
              </div>
            <% } else { %>
              <% favoriteRecipes.forEach(recipe => { %>
                <div class="detail-section" style="padding: 1rem; margin-bottom: 0; display: flex; align-items: center; gap: 1rem; cursor: pointer;" onclick="window.location.href='/recipes/<%= recipe.id %>'">
                  <% if (recipe.image_path) { %>
                    <img src="<%= recipe.image_path %>" alt="<%= recipe.title %>" style="width: 60px; height: 60px; border-radius: var(--radius-md); object-fit: cover;">
                  <% } else { %>
                    <div style="width: 60px; height: 60px; border-radius: var(--radius-md); background: var(--primary-glow); color: var(--primary); display: flex; align-items: center; justify-content: center;">
                      <img src="/images/placeholder.png?v=2" alt="Placeholder" style="width: 36px; height: 36px; opacity: 0.25; object-fit: contain; border-radius: var(--radius-sm);">
                    </div>
                  <% } %>
                  <div style="overflow: hidden; flex-grow: 1;">
                    <h4 style="font-size: 0.95rem; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 0.15rem;"><%= recipe.title %></h4>
                    <span style="font-size: 0.8rem; color: var(--text-secondary);"><%= recipe.total_time ? formatDuration(recipe.total_time) : '-- min' %></span>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>

        <div>
          <h3 class="mb-4">Collections</h3>
          <div style="display: flex; flex-direction: column; gap: 0.75rem;">
            <% if (collections.length === 0) { %>
              <div style="padding: 2rem; text-align: center; border: 1px dashed var(--border); border-radius: var(--radius-lg); color: var(--text-muted);">
                <p style="font-size: 0.85rem;">No collections. Click "+" in the sidebar to create one.</p>
              </div>
            <% } else { %>
              <% collections.slice(0, 5).forEach(c => { %>
                <a href="/collections/<%= c.id %>" class="detail-section" style="padding: 0.85rem 1.25rem; margin-bottom: 0; display: flex; justify-content: space-between; align-items: center; text-decoration: none;">
                  <div class="flex items-center gap-2">
                    <span class="collection-dot" style="background: <%= c.color %>; width: 8px; height: 8px;"></span>
                    <span style="font-weight: 600; font-size: 0.95rem; color: var(--text-primary);"><%= c.name %></span>
                  </div>
                  <span class="badge"><%= c.recipe_count || 0 %></span>
                </a>
              <% }) %>
              <% if (collections.length > 5) { %>
                <a href="/collections" style="text-align: center; font-size: 0.85rem; color: var(--primary); font-weight: 600; margin-top: 0.5rem; display: block;">See all collections</a>
              <% } %>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  <% } %>
<% } %>
</div>
