<div style="max-width: 900px; margin: 0 auto; display: flex; flex-direction: column; gap: 2rem;">
  <div id="pre-scraped-data" style="display: none;" data-recipe="<%= typeof preScraped !== 'undefined' && preScraped ? preScraped : '' %>"></div>

  <!-- Import Method Tabs -->
  <div class="detail-section" style="padding: 0; overflow: hidden;">
    <!-- Tab Nav -->
    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; border-bottom: 2px solid var(--color-border);">
      <button id="tab-url" onclick="switchImportTab('url')" class="import-tab active" style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 1.1rem 1rem; font-weight: 700; font-size: 0.95rem; background: transparent; border: none; cursor: pointer; border-bottom: 3px solid var(--primary); color: var(--text-primary); transition: all 0.2s;">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        Import from URL
      </button>
      <button id="tab-photo" onclick="switchImportTab('photo')" class="import-tab" style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 1.1rem 1rem; font-weight: 700; font-size: 0.95rem; background: transparent; border: none; cursor: pointer; border-bottom: 3px solid transparent; color: var(--text-secondary); transition: all 0.2s;">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>
        Scan Photo / OCR
      </button>
      <button id="tab-bookmark" onclick="switchImportTab('bookmark')" class="import-tab" style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 1.1rem 1rem; font-weight: 700; font-size: 0.95rem; background: transparent; border: none; cursor: pointer; border-bottom: 3px solid transparent; color: var(--text-secondary); transition: all 0.2s;">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
        Browser Bookmarklet
      </button>
    </div>

    <!-- ====== TAB: URL ====== -->
    <div id="panel-url" class="import-panel" style="padding: 2rem;">
      <h3 style="margin-top: 0; margin-bottom: 0.5rem;">Import from a Recipe Website</h3>
      <p style="color: var(--text-secondary); margin-bottom: 1.5rem; font-size: 0.95rem;">Paste any recipe URL. Savor will extract ingredients, instructions, times, and images automatically.</p>
      <form id="import-url-form" class="flex gap-2">
        <input type="url" id="import-url" class="form-control" placeholder="e.g. https://www.food.com/recipe/..." value="<%= typeof importUrl !== 'undefined' ? importUrl : '' %>" required style="flex-grow: 1;">
        <button type="submit" class="btn btn-primary" id="import-btn">
          <span class="btn-text">Import</span>
          <div class="spinner" id="import-spinner" style="display: none; width: 18px; height: 18px; border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff; border-radius: 50%; animation: spin 1s linear infinite;"></div>
        </button>
      </form>
      <p style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.75rem;">
        ✅ Works great with: food.com, BBC Good Food, Epicurious, Food Network, Delish, Budget Bytes, and most food blogs.<br>
        ⚠️ Blocked by AllRecipes/Simply Recipes? Use the <a href="#" onclick="switchImportTab('bookmark'); return false;" style="color: var(--primary);">Bookmarklet tab</a> instead.
      </p>
    </div>

    <!-- ====== TAB: PHOTO / OCR ====== -->
    <div id="panel-photo" class="import-panel" style="padding: 2rem; display: none;">
      <h3 style="margin-top: 0; margin-bottom: 0.5rem;">Scan a Recipe Photo</h3>
      <p style="color: var(--text-secondary); margin-bottom: 1.5rem; font-size: 0.95rem;">Take a photo or upload an image of a printed or handwritten recipe. Savor will read the text and pre-fill the import form for you to review.</p>

      <!-- Drop Zone -->
      <div id="ocr-drop-zone" onclick="document.getElementById('ocr-file-input').click()" style="border: 2px dashed var(--color-border); border-radius: var(--radius-lg); padding: 3rem 2rem; text-align: center; cursor: pointer; transition: border-color 0.2s, background 0.2s;" onmouseover="this.style.borderColor='var(--primary)'; this.style.background='var(--primary-glow)'" onmouseout="this.style.borderColor='var(--color-border)'; this.style.background='transparent'">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 1rem; opacity: 0.7;"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>
        <div style="font-weight: 700; font-size: 1.05rem; margin-bottom: 0.5rem;">Click to upload or drag & drop</div>
        <div style="font-size: 0.85rem; color: var(--text-secondary);">JPG, PNG, WEBP, HEIC supported</div>
      </div>
      <input type="file" id="ocr-file-input" accept="image/*" capture="environment" style="display: none;" onchange="handleOcrFileSelect(this)">

      <!-- Camera button for mobile -->
      <div style="display: flex; gap: 1rem; margin-top: 1rem;">
        <button type="button" class="btn btn-secondary" style="flex: 1; display: flex; align-items: center; justify-content: center; gap: 0.5rem;" onclick="document.getElementById('ocr-file-input').click()">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          Upload Image
        </button>
        <button type="button" class="btn btn-secondary" id="camera-btn" style="flex: 1; display: flex; align-items: center; justify-content: center; gap: 0.5rem;" onclick="openCamera()">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>
          Take Photo
        </button>
      </div>

      <!-- OCR Preview / Status -->
      <div id="ocr-status" style="display: none; margin-top: 1.5rem;"></div>

      <!-- Camera capture overlay -->
      <div id="camera-overlay" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.95); z-index: 9999; display: none; flex-direction: column; align-items: center; justify-content: center;">
        <video id="camera-feed" autoplay playsinline style="max-width: 100%; max-height: 70vh; border-radius: var(--radius-lg);"></video>
        <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
          <button onclick="captureFromCamera()" class="btn btn-primary" style="font-size: 1.1rem; padding: 0.85rem 2rem;">📸 Capture</button>
          <button onclick="closeCamera()" class="btn btn-secondary">Cancel</button>
        </div>
        <canvas id="camera-canvas" style="display: none;"></canvas>
      </div>
    </div>

    <!-- ====== TAB: BOOKMARKLET ====== -->
    <div id="panel-bookmark" class="import-panel" style="padding: 2rem; display: none;">
      <h3 style="margin-top: 0; margin-bottom: 0.5rem;">Browser Bookmarklet</h3>
      <p style="color: var(--text-secondary); margin-bottom: 1.5rem; font-size: 0.95rem;">
        The bookmarklet works on <strong>any website</strong> — including AllRecipes, NYT Cooking, and any site that blocks server-side scraping. When you're on a recipe page, just click it to instantly send the recipe to Savor.
      </p>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem;">
        <div style="background: var(--color-bg-tertiary); border-radius: var(--radius-md); padding: 1.25rem; display: flex; gap: 0.75rem; align-items: flex-start;">
          <div style="font-size: 1.5rem; flex-shrink: 0;">1️⃣</div>
          <div>
            <div style="font-weight: 700; margin-bottom: 0.25rem;">Make your bookmarks bar visible</div>
            <div style="font-size: 0.85rem; color: var(--text-secondary);">In Chrome: Ctrl+Shift+B &nbsp;|&nbsp; Firefox: Ctrl+B</div>
          </div>
        </div>
        <div style="background: var(--color-bg-tertiary); border-radius: var(--radius-md); padding: 1.25rem; display: flex; gap: 0.75rem; align-items: flex-start;">
          <div style="font-size: 1.5rem; flex-shrink: 0;">2️⃣</div>
          <div>
            <div style="font-weight: 700; margin-bottom: 0.25rem;">Drag the button below to your bookmarks bar</div>
            <div style="font-size: 0.85rem; color: var(--text-secondary);">Don't click it — drag it!</div>
          </div>
        </div>
        <div style="background: var(--color-bg-tertiary); border-radius: var(--radius-md); padding: 1.25rem; display: flex; gap: 0.75rem; align-items: flex-start;">
          <div style="font-size: 1.5rem; flex-shrink: 0;">3️⃣</div>
          <div>
            <div style="font-weight: 700; margin-bottom: 0.25rem;">Browse to any recipe page</div>
            <div style="font-size: 0.85rem; color: var(--text-secondary);">AllRecipes, NYT Cooking, anywhere</div>
          </div>
        </div>
        <div style="background: var(--color-bg-tertiary); border-radius: var(--radius-md); padding: 1.25rem; display: flex; gap: 0.75rem; align-items: flex-start;">
          <div style="font-size: 1.5rem; flex-shrink: 0;">4️⃣</div>
          <div>
            <div style="font-weight: 700; margin-bottom: 0.25rem;">Click "Savor Importer" in your bookmarks bar</div>
            <div style="font-size: 0.85rem; color: var(--text-secondary);">Savor opens with the recipe pre-filled!</div>
          </div>
        </div>
      </div>

      <!-- The actual draggable bookmarklet button -->
      <%
        const _importOrigin = typeof origin !== 'undefined' ? origin : '';
        const _importBkHref = "javascript:(function(){var ldTags=Array.from(document.querySelectorAll('script[type=\"application/ld+json\"]'));var recipeData=null;for(var i=0;i<ldTags.length;i++){try{var j=JSON.parse(ldTags[i].textContent);if(j['@type']==='Recipe'||(Array.isArray(j)&&j.some(function(x){return x['@type']==='Recipe'}))||(j['@graph']&&j['@graph'].some(function(x){return x['@type']==='Recipe'}))){recipeData=j;break;}}catch(e){}}var form=document.createElement('form');form.method='POST';form.action='" + _importOrigin + "/recipes/new?import=1';form.target='_blank';var u=document.createElement('input');u.type='hidden';u.name='url';u.value=window.location.href;form.appendChild(u);if(recipeData){var d=document.createElement('input');d.type='hidden';d.name='recipe_json';d.value=JSON.stringify(recipeData);form.appendChild(d);}document.body.appendChild(form);form.submit();document.body.removeChild(form);})();";
      %>
      <div style="text-align: center; padding: 2.5rem; border: 2px dashed var(--primary); border-radius: var(--radius-lg); background: var(--primary-glow);">
        <p style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 1.25rem;">👇 Drag this button to your browser's bookmarks bar</p>
        <a href="<%= _importBkHref %>"
           class="btn btn-primary"
           style="cursor: grab; display: inline-flex; align-items: center; gap: 0.6rem; font-size: 1.05rem; padding: 0.85rem 2rem; user-select: none; box-shadow: 0 4px 20px rgba(0,0,0,0.3);"
           onclick="event.preventDefault(); alert('Drag this button to your bookmarks bar — don\'t click it here!');">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
          Savor Importer
        </a>
        <p style="font-size: 0.78rem; color: var(--text-muted); margin-top: 0.75rem;">Reads recipe data directly from your browser — no server requests needed</p>
      </div>
    </div>

  </div>

  <!-- Duplicate Match Alert Banner -->
  <div id="duplicate-warning" class="detail-section" style="display: none; border-left: 5px solid var(--accent); background-color: var(--primary-glow);">
    <div style="display: flex; gap: 1rem; align-items: flex-start;">
      <div style="color: var(--accent); font-size: 1.5rem; line-height: 1;">⚠</div>
      <div style="flex-grow: 1;">
        <h4 style="font-weight: 700; margin-bottom: 0.25rem;">Duplicate Recipe Detected</h4>
        <p style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 1rem;" id="duplicate-message">A recipe with this URL or title already exists in your library.</p>
        <div style="display: flex; gap: 1rem;">
          <button type="button" class="btn btn-primary btn-sm" id="duplicate-update-btn" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; background-color: var(--accent);">Update Existing Recipe</button>
          <button type="button" class="btn btn-secondary btn-sm" id="duplicate-anyway-btn" style="padding: 0.4rem 0.8rem; font-size: 0.8rem;">Import as Duplicate</button>
          <button type="button" class="btn btn-ghost btn-sm" id="duplicate-cancel-btn" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; color: var(--text-secondary);">Cancel</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Loading State Indicator -->
  <div id="import-loading-placeholder" class="detail-section text-center" style="display: none; padding: 4rem 2rem;">
    <div class="spinner" style="width: 48px; height: 48px; border: 4px solid var(--primary-glow); border-top-color: var(--primary); border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto 1.5rem auto;"></div>
    <h3>Fetching Recipe...</h3>
    <p style="color: var(--text-secondary); margin-top: 0.5rem;">Analyzing structured metadata and scraping website contents.</p>
  </div>

  <!-- Preview Area -->
  <div id="import-preview-section" class="detail-section" style="display: none;">
    <h3 class="mb-4">Verify Extracted Recipe</h3>
    <form id="import-save-form">
      <input type="hidden" name="source_url" id="preview-source-url">
      <input type="hidden" name="image_url" id="preview-image-url">
      
      <div class="form-group">
        <label for="preview-title" class="form-label">Title *</label>
        <input type="text" id="preview-title" name="title" class="form-control" required>
      </div>

      <div class="form-group">
        <label for="preview-description" class="form-label">Description</label>
        <textarea id="preview-description" name="description" class="form-control"></textarea>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
        <div class="form-group">
          <label for="preview-collection" class="form-label">Collection</label>
          <select id="preview-collection" name="collection_id" class="form-control">
            <option value="">Uncollected</option>
            <% collections.forEach(c => { %>
              <option value="<%= c.id %>"><%= c.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label for="preview-servings" class="form-label">Servings</label>
          <input type="text" id="preview-servings" name="servings" class="form-control">
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem;">
        <div class="form-group">
          <label for="preview-prep" class="form-label">Prep Time (mins)</label>
          <input type="number" id="preview-prep" name="prep_time" class="form-control" min="0">
        </div>
        <div class="form-group">
          <label for="preview-cook" class="form-label">Cook Time (mins)</label>
          <input type="number" id="preview-cook" name="cook_time" class="form-control" min="0">
        </div>
        <div class="form-group">
          <label for="preview-total" class="form-label">Total Time (mins)</label>
          <input type="number" id="preview-total" name="total_time" class="form-control" min="0">
        </div>
      </div>

      <div class="form-group">
        <label for="preview-ingredients" class="form-label">Ingredients (one per line) *</label>
        <textarea id="preview-ingredients" name="ingredients" class="form-control" style="min-height: 180px;" required></textarea>
      </div>

      <div class="form-group">
        <label for="preview-instructions" class="form-label">Instructions (one step per line) *</label>
        <textarea id="preview-instructions" name="instructions" class="form-control" style="min-height: 180px;" required></textarea>
      </div>

      <div class="form-group">
        <label for="preview-notes" class="form-label">Notes (Optional)</label>
        <textarea id="preview-notes" name="notes" class="form-control"></textarea>
      </div>

      <div class="form-group">
        <label for="preview-tags" class="form-label">Tags (comma-separated)</label>
        <input type="text" id="preview-tags" name="tags" class="form-control" placeholder="e.g. dinner, chicken, healthy">
      </div>

      <div class="form-group">
        <label class="form-label">Imported Image</label>
        <div style="display: flex; gap: 1.5rem; align-items: center;">
          <div id="preview-image-container" style="width: 120px; height: 120px; border-radius: var(--radius-md); border: 1px solid var(--border); overflow: hidden; display: flex; align-items: center; justify-content: center; background-color: var(--bg-tertiary);">
            <img id="preview-image" style="width: 100%; height: 100%; object-fit: cover; display: none;">
            <span id="preview-image-none" style="font-size: 0.75rem; color: var(--text-muted); text-align: center; padding: 0.5rem;">No image found</span>
          </div>
          <p style="font-size: 0.85rem; color: var(--text-secondary); max-width: 400px;">The recipe image will be downloaded and optimized directly onto Savor's local storage. Savor never hotlinks remote images.</p>
        </div>
      </div>

      <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 2.5rem; border-top: 1px solid var(--border); padding-top: 1.5rem;">
        <button type="button" class="btn btn-secondary" onclick="resetImportPage()">Clear</button>
        <button type="submit" class="btn btn-primary" id="save-import-btn">Save Recipe</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/import.js"></script>

<style>
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  .import-tab:hover { color: var(--text-primary) !important; }
  .import-tab.active { color: var(--text-primary) !important; border-bottom-color: var(--primary) !important; }

  #ocr-drop-zone.drag-over {
    border-color: var(--primary) !important;
    background: var(--primary-glow) !important;
  }
</style>

<script>
function switchImportTab(tab) {
  // Hide all panels
  document.querySelectorAll('.import-panel').forEach(p => p.style.display = 'none');
  document.querySelectorAll('.import-tab').forEach(t => {
    t.classList.remove('active');
    t.style.borderBottomColor = 'transparent';
    t.style.color = 'var(--text-secondary)';
  });

  // Show selected
  document.getElementById('panel-' + tab).style.display = 'block';
  const activeTab = document.getElementById('tab-' + tab);
  activeTab.classList.add('active');
  activeTab.style.borderBottomColor = 'var(--primary)';
  activeTab.style.color = 'var(--text-primary)';
}

// OCR: file drag-and-drop
const dropZone = document.getElementById('ocr-drop-zone');
if (dropZone) {
  dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
  dropZone.addEventListener('drop', e => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');
    const file = e.dataTransfer.files[0];
    if (file && file.type.startsWith('image/')) processOcrFile(file);
  });
}

function handleOcrFileSelect(input) {
  const file = input.files[0];
  if (file) processOcrFile(file);
}

function processOcrFile(file) {
  const status = document.getElementById('ocr-status');
  status.style.display = 'block';
  status.innerHTML = `
    <div style="display: flex; align-items: center; gap: 1rem; padding: 1.25rem; background: var(--color-bg-tertiary); border-radius: var(--radius-md);">
      <div class="spinner" style="width: 24px; height: 24px; border: 3px solid var(--primary-glow); border-top-color: var(--primary); border-radius: 50%; animation: spin 1s linear infinite; flex-shrink: 0;"></div>
      <div>
        <div style="font-weight: 700;">Reading recipe text...</div>
        <div style="font-size: 0.82rem; color: var(--text-secondary);">This may take 10–20 seconds for multi-column images</div>
      </div>
    </div>`;

  const formData = new FormData();
  formData.append('image', file);

  fetch('/api/import/ocr', { method: 'POST', body: formData })
    .then(r => r.json())
    .then(data => {
      if (data.error) throw new Error(data.error);

      // Build status with raw OCR collapsible
      const rawSection = data.rawText ? `
        <details style="margin-top: 0.75rem;">
          <summary style="cursor: pointer; font-size: 0.82rem; color: var(--text-secondary); user-select: none; padding: 0.4rem 0;">
            📄 View raw OCR text (use this if auto-parsing missed anything)
          </summary>
          <textarea readonly style="width: 100%; margin-top: 0.5rem; min-height: 180px; font-size: 0.78rem; font-family: monospace; background: var(--color-bg-tertiary); border: 1px solid var(--color-border); border-radius: var(--radius-sm); padding: 0.75rem; color: var(--text-secondary); resize: vertical;">${data.rawText.replace(/</g,'&lt;').replace(/>/g,'&gt;')}</textarea>
        </details>` : '';

      status.innerHTML = `
        <div style="padding: 0.75rem 1rem; background: var(--color-bg-tertiary); border-radius: var(--radius-md); border-left: 4px solid var(--primary);">
          <div style="font-weight: 700; margin-bottom: 0.25rem;">✅ Text extracted! Review and edit the fields below.</div>
          <div style="font-size: 0.82rem; color: var(--text-secondary);">The auto-parser works best with single-column recipes. For two-column recipe cards, check the raw text below and manually clean up any mixed lines.</div>
          ${rawSection}
        </div>`;

      // Populate preview form
      if (data.title) document.getElementById('preview-title').value = data.title;
      if (data.ingredients) document.getElementById('preview-ingredients').value = data.ingredients;
      if (data.instructions) document.getElementById('preview-instructions').value = data.instructions;
      if (data.servings) document.getElementById('preview-servings').value = data.servings;
      document.getElementById('import-preview-section').style.display = 'block';
      document.getElementById('import-preview-section').scrollIntoView({ behavior: 'smooth' });
    })
    .catch(err => {
      status.innerHTML = `<div style="padding: 0.75rem 1rem; background: var(--color-bg-tertiary); border-radius: var(--radius-md); border-left: 4px solid var(--accent); color: var(--text-secondary);">❌ ${err.message}. Try a clearer photo or type the recipe manually.</div>`;
    });
}


// Camera support
let cameraStream = null;
function openCamera() {
  const overlay = document.getElementById('camera-overlay');
  overlay.style.display = 'flex';
  navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' }, audio: false })
    .then(stream => {
      cameraStream = stream;
      document.getElementById('camera-feed').srcObject = stream;
    })
    .catch(() => {
      overlay.style.display = 'none';
      // Fallback to file input with camera
      const input = document.getElementById('ocr-file-input');
      input.setAttribute('capture', 'environment');
      input.click();
    });
}
function closeCamera() {
  if (cameraStream) cameraStream.getTracks().forEach(t => t.stop());
  document.getElementById('camera-overlay').style.display = 'none';
}
function captureFromCamera() {
  const video = document.getElementById('camera-feed');
  const canvas = document.getElementById('camera-canvas');
  canvas.width = video.videoWidth;
  canvas.height = video.videoHeight;
  canvas.getContext('2d').drawImage(video, 0, 0);
  closeCamera();
  canvas.toBlob(blob => {
    const file = new File([blob], 'camera-capture.jpg', { type: 'image/jpeg' });
    processOcrFile(file);
    switchImportTab('photo');
  }, 'image/jpeg', 0.9);
}
</script>
