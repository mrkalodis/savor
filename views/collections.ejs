<div style="display: flex; flex-direction: column; gap: 2rem;">
  <div class="flex justify-between items-center">
    <h2>Collections</h2>
    <button class="btn btn-primary" onclick="openModal('create-collection-modal')">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      <span>New Collection</span>
    </button>
  </div>

  <% if (collections.length === 0) { %>
    <div class="empty-state detail-section">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
      </svg>
      <h3>No collections defined</h3>
      <p>Collections let you group recipes by categories like Dinner, Breakfast, Desserts, and more.</p>
      <button class="btn btn-primary" onclick="openModal('create-collection-modal')">Add Collection</button>
    </div>
  <% } else { %>
    <p style="color: var(--text-secondary); margin-bottom: -1rem; font-size: 0.9rem;">Tip: You can reorder collections by dragging them in the sidebar navigation.</p>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 2rem;">
      <% collections.forEach(c => { %>
        <div class="detail-section" style="border-top: 6px solid <%= c.color %>; margin-bottom: 0; cursor: pointer; display: flex; flex-direction: column; justify-content: space-between; height: 180px; transition: transform var(--transition-normal);" onclick="window.location.href='/collections/<%= c.id %>'">
          <div>
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.5rem;">
              <h4 style="font-size: 1.15rem; font-weight: 700; color: var(--text-primary);"><%= c.name %></h4>
              <span class="badge" style="background-color: var(--primary-glow); color: var(--primary);"><%= c.recipe_count || 0 %> recipes</span>
            </div>
            <% if (c.description) { %>
              <p style="font-size: 0.875rem; color: var(--text-secondary); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"><%= c.description %></p>
            <% } else { %>
              <p style="font-size: 0.875rem; color: var(--text-muted); font-style: italic;">No description provided.</p>
            <% } %>
          </div>
          
          <div style="font-size: 0.8rem; color: var(--primary); font-weight: 600; display: flex; align-items: center; gap: 0.25rem;">
            <span>Browse Collection</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
